        "en_female_sarah": "澳英女声"
      }
    },
    {
      "key": "ja-voiceType",
      "display": "日文音色",
      "type": "select",
      "options": {
        "jp_male_satoshi": "日语男声",
        "jp_female_hana": "日语女声"
      }
    },
    {
      "key": "speedRatio",
      "display": "语速 (0.2-3)",
