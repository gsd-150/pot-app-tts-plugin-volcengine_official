    {
      "key": "appid",
      "display": "App ID",
      "type": "input"
    },
    {
      "key": "accessToken",
      "display": "Access Token",
      "type": "input"
    },
    {
      "key": "cluster",
      "display": "Cluster ID",
      "type": "input"
    },
    {
      "key": "zh_cn-voiceType",
      "display": "中文音色",
